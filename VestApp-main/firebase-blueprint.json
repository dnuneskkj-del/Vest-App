{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "coverURL": { "type": "string" },
        "handle": { "type": "string" },
        "bio": { "type": "string" },
        "level": { "type": "integer" },
        "xp": { "type": "integer" },
        "followersCount": { "type": "integer" },
        "followingCount": { "type": "integer" },
        "totalFocusSeconds": { "type": "integer" },
        "simuladosCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "handle"]
    },
    "Post": {
      "title": "Post",
      "description": "Social media post",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageURL": { "type": "string" },
        "subject": { "type": "string" },
        "likesCount": { "type": "integer" },
        "commentsCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "authorName", "content", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "Post like",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "postId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Post comment",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "authorName", "text", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "Follow relationship",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "Presence": {
      "title": "Presence",
      "description": "User online status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "status", "lastSeen"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Personalized study schedule",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "plan": { "type": "object" },
        "preferences": { "type": "object" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "plan", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification for interactions",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow"] },
        "postId": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["recipientId", "senderId", "senderName", "type", "message", "read", "createdAt"]
    },
    "EssaySubmission": {
      "title": "EssaySubmission",
      "description": "ENEM essay submission result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "theme": { "type": "string" },
        "score": { "type": "integer" },
        "competencies": { "type": "array" },
        "evaluation": { "type": "object" },
        "submissionMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "theme", "score", "createdAt"]
    },
    "SimuladoResult": {
      "title": "SimuladoResult",
      "description": "Simulation exam result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "examId": { "type": "string" },
        "examTitle": { "type": "string" },
        "difficulty": { "type": "string" },
        "correctAnswers": { "type": "integer" },
        "totalQuestions": { "type": "integer" },
        "timeSeconds": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "examId", "examTitle", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Global feed of posts"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a specific post"
    },
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "Likes tracking (id is userId_postId)"
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Follow relationships (id is followerId_followingId)"
    },
    "/presence/{userId}": {
      "schema": "Presence",
      "description": "Online status tracking"
    },
    "/schedules/{userId}": {
      "schema": "Schedule",
      "description": "User study schedules"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/essay_submissions/{submissionId}": {
      "schema": "EssaySubmission",
      "description": "User essay submissions"
    },
    "/simulado_results/{resultId}": {
      "schema": "SimuladoResult",
      "description": "User simulation results"
    }
  }
}
